# Email credentials (IMAP)
IMAP_SERVER=imap.example.com
IMAP_PORT=993
IMAP_SSL=true
IMAP_STARTTLS=false
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_password
TRASH_FOLDER=Trash

# Monitoring
HEALTHCHECK_URL=https://hc-ping.com/your_healthcheck_id/waypoint

# Redirect settings
# Seconds shown on the redirect fallback page before it navigates to the
# LiveTrack link. Only used when a link cannot be embedded in an iframe --
# see README's "Display mode" section; there is no manual iframe/redirect
# toggle, it is detected automatically per link.
REDIRECT_COUNTDOWN=10

# Web server
# Port the built-in web server listens on inside the container.
WEB_PORT=8080

# Admin interface (dashboard, manual link override, history) at /admin.
# Leave both unset to disable the admin interface entirely (404).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Directory the current link and history are persisted to (JSON file).
# Should point at a mounted volume so state survives a container restart.
STATE_DIR=/data

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
