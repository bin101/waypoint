# Environment variables - NEVER commit!
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Persisted runtime state (mounted volume content)
/data/

# Test runner
.pytest_cache/

# Raw email captures potentially containing personal data - never commit these.
# Sanitized fixtures belong in tests/fixtures/ and are exempt below.
/testmail*.eml
*.eml
!tests/fixtures/*.eml